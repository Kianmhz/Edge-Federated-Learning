# ---- Transport Mode ----
# "http"        = original REST polling (no Azure needed)
# "servicebus"  = Azure Service Bus (event-driven)
FL_TRANSPORT=http

# ---- Azure Service Bus ----
# Get from: az servicebus namespace authorization-rule keys list ...
AZURE_SERVICEBUS_CONNECTION_STRING=

# ---- Azure Blob Storage (claim-check pattern) ----
# Get from: az storage account show-connection-string ...
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=fl-model-weights

# ---- Service Bus Topic / Queue Names (defaults are fine) ----
# SB_ROUND_CONTROL_TOPIC=round-control
# SB_GLOBAL_MODEL_TOPIC=global-model
# SB_CLIENT_UPDATES_QUEUE=client-updates
# SB_DASHBOARD_EVENTS_QUEUE=dashboard-events

# ---- Federated Learning Tuning ----
# FL_PARTICIPATION_PROB=0.5
# FL_AGG_TIMEOUT=45.0
